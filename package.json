{
  "name": "seat-scoring-app",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:coverage": "vitest run --config vitest.config.unit.ts --coverage",
    "test:api": "vitest run --config vitest.config.api.ts",
    "test:api:coverage": "vitest run --config vitest.config.api.ts --coverage",
    "test:all": "npm run test:unit:coverage && npm run test:api:coverage",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "fake-indexeddb": "^6.0.0",
    "svelte": "^5.25.3",
    "svelte-check": "^4.1.5",
    "typescript": "~5.7.0",
    "vite": "^6.2.4",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "svelte-spa-router": "^4.0.1"
  }
}
